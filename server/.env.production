# Production Environment Configuration
# Copy this to .env for production deployment

# Server
NODE_ENV=production
PORT=5001

# MongoDB (update with your production MongoDB connection string)
MONGO_URI=mongodb://localhost:27017/pharmacy_production

# JWT Secret (generate a strong secret for production!)
JWT_SECRET=your_super_secure_jwt_secret_key_here_min_32_chars

# Client URL (for CORS in production)
CLIENT_URL=http://localhost:5001

# Optional: Socket.io settings
# SOCKET_PORT=5001