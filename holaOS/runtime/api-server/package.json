    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.8.0",
    "cron-parser": "^5.5.0",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.1",
    "node-pty": "^1.2.0-beta.12",
    "tar": "^7.5.13",
    "yauzl": "^3.2.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "path-to-regexp": "^8.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/tar": "^6.1.13",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "yazl": "^3.3.1"
  }
}
