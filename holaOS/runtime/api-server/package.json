{
  "name": "@holaboss/runtime-api-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "holaboss-runtime-api": "dist/index.mjs",
    "holaboss-runtime-runtime-config": "dist/runtime-config-cli.mjs",
    "holaboss-runtime-workspace-runtime-plan": "dist/workspace-runtime-plan.mjs",
    "holaboss-runtime-workspace-mcp-host": "dist/workspace-mcp-host.mjs",
    "holaboss-runtime-workspace-mcp-sidecar": "dist/workspace-mcp-sidecar.mjs"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
