{
  "name": "docs-next",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "cf:types": "wrangler types --env-interface Env",
    "deploy:preview": "bun run build && wrangler deploy --env preview",
    "deploy:staging": "bun run build && wrangler deploy --env staging",
    "deploy:production": "bun run build && wrangler deploy --env production"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@takumi-rs/image-response": "^1.0.9",
    "fumadocs-core": "16.7.16",
    "fumadocs-mdx": "14.3.0",
    "fumadocs-ui": "16.7.16",
    "isbot": "^5.1.38",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@cloudflare/vite-plugin": "^1.32.3",
    "@react-router/dev": "^7.14.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wrangler": "^4.83.0"
  }
}